---
layout: page
title: "Contact — Apex Agency"
description: "Ready to accelerate your growth? Get in touch with our team for a free discovery consultation."
permalink: /contact/
page_label: "Contact"
page_subtitle: "Let's build something extraordinary together."
---

<!-- ════════════════════════════════════════════════════════════
     CONTACT SECTION
     ════════════════════════════════════════════════════════════ -->
<section class="section">
  <div class="container-page">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20">
      <!-- Contact Info Sidebar -->
      <aside class="lg:col-span-2" data-animate>
        <h2 class="font-display text-heading-xl font-bold mb-6">Let's Start a Conversation</h2>
        <p class="text-body text-midnight/60 mb-8 leading-relaxed">
          Tell us about your brand and your ambitions. We'll respond within 
          24 hours with a personalized growth perspective — no strings attached.
        </p>

        <!-- Contact Details -->
        <div class="space-y-6 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-body font-semibold text-body-sm mb-1">Email</h3>
              <a href="mailto:{{ site.email }}" class="text-body-sm text-midnight/60 hover:text-gold transition-colors">{{ site.email }}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-body font-semibold text-body-sm mb-1">Phone</h3>
              <a href="tel:{{ site.phone | replace: ' ', '' }}" class="text-body-sm text-midnight/60 hover:text-gold transition-colors">{{ site.phone }}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-gold/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-body font-semibold text-body-sm mb-1">Office</h3>
              <address class="not-italic text-body-sm text-midnight/60">
                {{ site.address.line1 }}<br>
                {{ site.address.line2 }}<br>
                {{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}
              </address>
            </div>
          </div>
        </div>

        <!-- Office Hours -->
        <div class="p-6 rounded-lg bg-cloud-dark/50 mb-8">
          <h3 class="font-display text-heading font-semibold mb-4">Office Hours</h3>
          <dl class="space-y-2 text-body-sm">
            <div class="flex justify-between">
              <dt class="text-midnight/50">Weekdays</dt>
              <dd class="font-medium">{{ site.office_hours.weekday }}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-midnight/50">Saturday</dt>
              <dd class="font-medium">{{ site.office_hours.saturday }}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-midnight/50">Sunday</dt>
              <dd class="font-medium">{{ site.office_hours.sunday }}</dd>
            </div>
            <div class="pt-2 mt-2 border-t border-cloud-dark">
              <dt class="text-caption text-midnight/40">{{ site.office_hours.timezone }}</dt>
            </div>
          </dl>
        </div>

        <!-- Calendly Embed -->
        <a href="{{ site.calendly.demo_url }}" target="_blank" rel="noopener noreferrer" class="btn btn-gold-outline w-full">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Book a Discovery Call
        </a>
      </aside>

      <!-- Contact Form -->
      <div class="lg:col-span-3" data-animate data-delay="200">
        <div class="p-8 md:p-10 rounded-lg bg-white shadow-soft">
          <form data-contact-form novalidate>
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            
            <!-- Step 1: Basic Info -->
            <div data-form-step>
              <div class="flex items-center gap-3 mb-8">
                <span class="w-8 h-8 rounded-full bg-gold text-midnight flex items-center justify-center text-caption font-bold">1</span>
                <div>
                  <h3 class="font-display text-heading font-semibold">Your Information</h3>
                  <p class="text-caption text-midnight/50">Let us know who you are</p>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div data-char-count-container>
                  <label for="full_name" class="input-label">Full Name <span class="text-red-400">*</span></label>
                  <input type="text" id="full_name" name="full_name" class="input" required autocomplete="name" placeholder="John Smith" maxlength="100">
                  <p class="input-helper" data-error></p>
                </div>
                <div>
                  <label for="email" class="input-label">Email Address <span class="text-red-400">*</span></label>
                  <input type="email" id="email" name="email" class="input" required autocomplete="email" placeholder="john@company.com">
                  <p class="input-helper" data-error></p>
                </div>
                <div>
                  <label for="phone" class="input-label">Phone Number</label>
                  <input type="tel" id="phone" name="phone" class="input" autocomplete="tel" placeholder="+1 (555) 000-0000">
                  <p class="input-helper" data-error></p>
                </div>
                <div>
                  <label for="company" class="input-label">Company Name <span class="text-red-400">*</span></label>
                  <input type="text" id="company" name="company" class="input" required placeholder="Your Company Inc.">
                  <p class="input-helper" data-error></p>
                </div>
              </div>

              <div class="flex justify-end mt-8">
                <button type="button" data-next-step class="btn btn-primary">
                  Next Step
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Step 2: Project Details -->
            <div data-form-step style="display:none;">
              <div class="flex items-center gap-3 mb-8">
                <span class="w-8 h-8 rounded-full bg-gold text-midnight flex items-center justify-center text-caption font-bold">2</span>
                <div>
                  <h3 class="font-display text-heading font-semibold">Project Details</h3>
                  <p class="text-caption text-midnight/50">Tell us about your goals</p>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                  <label for="budget" class="input-label">Budget Range</label>
                  <select id="budget" name="budget" class="input">
                    <option value="">Select a range</option>
                    <option value="<5k">Under $5,000</option>
                    <option value="5k-15k">$5,000 — $15,000</option>
                    <option value="15k-50k">$15,000 — $50,000</option>
                    <option value="50k-100k">$50,000 — $100,000</option>
                    <option value=">100k">$100,000+</option>
                    <option value="not-sure">Not sure yet</option>
                  </select>
                </div>
                <div>
                  <label for="timeline" class="input-label">Desired Timeline</label>
                  <select id="timeline" name="timeline" class="input">
                    <option value="">Select a timeline</option>
                    <option value="asap">ASAP (within 2 weeks)</option>
                    <option value="1month">Within 1 month</option>
                    <option value="3months">Within 3 months</option>
                    <option value="6months">Within 6 months</option>
                    <option value="exploring">Just exploring</option>
                  </select>
                </div>
              </div>

              <div class="mb-6">
                <label class="input-label">Services Interested In</label>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {% for service in services.services %}
                  <label class="flex items-center gap-3 p-3 rounded-md border-2 border-cloud-dark hover:border-gold/50 cursor-pointer transition-colors has-[:checked]:border-gold has-[:checked]:bg-gold/5">
                    <input type="checkbox" name="services" value="{{ service.id }}" class="w-4 h-4 accent-gold">
                    <span class="text-body-sm font-medium">{{ service.title }}</span>
                  </label>
                  {% endfor %}
                </div>
              </div>

              <div>
                <label for="message" class="input-label">Tell Us About Your Project <span class="text-red-400">*</span></label>
                <textarea id="message" name="message" rows="5" class="input" required placeholder="Tell us about your brand, your goals, and what success looks like..." maxlength="2000"></textarea>
                <p class="input-helper" data-char-count></p>
                <p class="input-helper" data-error></p>
              </div>

              <div class="flex justify-between mt-8">
                <button type="button" data-prev-step class="btn btn-ghost">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
                  </svg>
                  Back
                </button>
                <button type="button" data-next-step class="btn btn-primary">
                  Review & Submit
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Step 3: Review & Submit -->
            <div data-form-step style="display:none;">
              <div class="flex items-center gap-3 mb-8">
                <span class="w-8 h-8 rounded-full bg-gold text-midnight flex items-center justify-center text-caption font-bold">3</span>
                <div>
                  <h3 class="font-display text-heading font-semibold">Review & Submit</h3>
                  <p class="text-caption text-midnight/50">One last check before we connect</p>
                </div>
              </div>

              <div class="p-6 rounded-lg bg-cloud-dark/30 mb-6">
                <h4 class="font-display text-heading font-semibold mb-4">Summary</h4>
                <dl class="space-y-3 text-body-sm">
                  <div class="flex justify-between">
                    <dt class="text-midnight/50">Name</dt>
                    <dd class="font-medium" id="summary-name"></dd>
                  </div>
                  <div class="flex justify-between">
                    <dt class="text-midnight/50">Email</dt>
                    <dd class="font-medium" id="summary-email"></dd>
                  </div>
                  <div class="flex justify-between">
                    <dt class="text-midnight/50">Company</dt>
                    <dd class="font-medium" id="summary-company"></dd>
                  </div>
                  <div class="flex justify-between">
                    <dt class="text-midnight/50">Budget</dt>
                    <dd class="font-medium" id="summary-budget"></dd>
                  </div>
                </dl>
              </div>

              <!-- File Upload -->
              <div class="mb-6">
                <label class="input-label">Supporting Files (optional)</label>
                <p class="text-caption text-midnight/50 mb-3">Upload a brief, deck, or any relevant materials (max 5MB)</p>
                <div data-file-upload class="file-upload-zone">
                  <div data-file-placeholder>
                    <svg class="w-10 h-10 mx-auto mb-3 text-midnight/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                    </svg>
                    <p class="text-body-sm text-midnight/40">Drop files here or <span class="text-gold font-medium">browse</span></p>
                  </div>
                  <input type="file" name="attachment" accept=".pdf,.doc,.docx,.ppt,.pptx,.png,.jpg,.zip" class="hidden">
                  <div data-file-preview></div>
                </div>
              </div>

              <!-- hCaptcha -->
              {% if site.hcaptcha_sitekey %}
              <div class="mb-6" data-hcaptcha-container>
                <div class="h-captcha" data-sitekey="{{ site.hcaptcha_sitekey }}"></div>
              </div>
              {% endif %}

              <!-- Error message -->
              <div data-form-error class="hidden p-4 rounded-md bg-red-50 text-red-600 text-body-sm mb-6"></div>

              <div class="flex justify-between mt-8">
                <button type="button" data-prev-step class="btn btn-ghost">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
                  </svg>
                  Edit Details
                </button>
                <button type="submit" data-submit-btn class="btn btn-primary btn-lg">
                  Send Message
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                  </svg>
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════
     NEWSLETTER SIGNUP
     ════════════════════════════════════════════════════════════ -->
<section class="section-dark relative overflow-hidden">
  <div class="absolute inset-0 bg-noise"></div>
  <div class="container-page relative z-10 text-center">
    <div data-animate>
      <span class="section-label">Stay Connected</span>
      <h2 class="section-title-light">Get Growth Insights Delivered</h2>
      <p class="section-desc section-desc-light mx-auto mt-4 max-w-xl">
        Weekly strategies, case studies, and industry analysis from our 
        team of growth experts.
      </p>

      <form action="/api/newsletter" method="POST" class="max-w-md mx-auto mt-8 flex gap-3">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input id="newsletter-email" type="email" name="email" required 
               class="flex-1 px-4 py-3 rounded-sm bg-white/10 border border-white/20 text-cloud placeholder:text-cloud/40 
                      focus:outline-none focus:border-gold focus:bg-white/15 transition-all"
               placeholder="Enter your email">
        <button type="submit" class="btn btn-primary whitespace-nowrap">
          Subscribe
        </button>
      </form>
      <p class="text-caption text-cloud/30 mt-4">
        No spam, ever. Unsubscribe anytime.
      </p>
    </div>
  </div>
</section>
