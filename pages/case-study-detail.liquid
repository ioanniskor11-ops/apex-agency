---
layout: default
title: "Case Studies — Apex Agency"
permalink: /case-studies/
redirect_to: /work/
---

{% assign cases = case_studies.case_studies %}
{% for case in cases %}
      <article class="case-study-card group" data-animate>
  <a href="{{ case.url | default: '/work/' }}" class="block relative h-80">
    {% if case.image %}
    <img src="{{ case.image }}" alt="{{ case.client }}" loading="lazy" class="w-full h-full object-cover">
{% endif %}
    <div class="case-study-overlay"></div>
    <div class="case-study-content">
      <span class="badge badge-gold mb-2 inline-block">{{ case.industry }}</span>
      <h2 class="font-display text-heading-xl font-bold text-cloud">{{ case.client }}</h2>
      <p class="text-body-sm text-cloud/60 mt-2">{{ case.short_description | truncate: 120 }}</p>
    </div>
  </a>
</article>
{% endfor %}

