---
layout: default
---

<!-- ── Page Header ───────────────────────────────────── -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-midnight overflow-hidden">
  <div class="absolute inset-0 bg-noise"></div>
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-20">
    <div class="absolute top-20 right-20 w-96 h-96 bg-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-gold/5 rounded-full blur-2xl"></div>
  </div>

  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      {% if page_label %}
      <span class="inline-block px-4 py-1.5 bg-gold/15 text-gold text-caption font-semibold uppercase tracking-widest rounded-sm mb-6">
        {{ page_label }}
      </span>
      {% endif %}

      <h1 class="font-display text-display-lg md:text-display-xl font-bold text-cloud leading-tight">
        {{ title }}
      </h1>

      {% if description %}
      <p class="mt-6 text-body-lg text-cloud/70 max-w-2xl leading-relaxed">
        {{ description }}
      </p>
      {% endif %}

      {% if page_subtitle %}
      <p class="mt-4 text-body text-gold/80 font-medium">
        {{ page_subtitle }}
      </p>
      {% endif %}
    </div>
  </div>

  <!-- Decorative bottom transition -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-cloud to-transparent"></div>
</section>

<!-- ── Page Content ──────────────────────────────────── -->
{{ content }}
