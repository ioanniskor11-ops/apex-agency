---
layout: default
permalink: /blog/{{ page.fileSlug }}/
---

<article itemscope itemtype="https://schema.org/BlogPosting">
  <!-- ── Post Hero ─────────────────────────────────────── -->
  <section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-midnight overflow-hidden">
    <div class="absolute inset-0 bg-noise"></div>
    {% if thumbnail %}
    <div class="absolute inset-0">
      <img src="{{ thumbnail }}" alt="" class="w-full h-full object-cover opacity-20" aria-hidden="true">
    </div>
    {% endif %}
    <div class="absolute top-0 right-0 w-1/3 h-full opacity-10">
      <div class="absolute top-20 right-20 w-64 h-64 bg-gold/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container-page relative z-10">
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="badge badge-gold">{{ category | default: "Insights" }}</span>
          <span class="text-cloud/40 text-caption">•</span>
          <time datetime="{{ date | date: '%Y-%m-%d' }}" class="text-caption text-cloud/50" itemprop="datePublished">{{ date | date_short }}</time>
          <span class="text-cloud/40 text-caption">•</span>
          <span class="text-caption text-cloud/50">{{ content | reading_time }}</span>
        </div>

        <h1 class="font-display text-display-lg md:text-display-xl font-bold text-cloud leading-tight mb-6" itemprop="headline">
          {{ title }}
        </h1>

        {% if excerpt %}
        <p class="text-body-lg text-cloud/60 max-w-2xl" itemprop="description">{{ excerpt }}</p>
        {% endif %}

        <!-- Author -->
        <div class="flex items-center gap-4 mt-8 pt-8 border-t border-white/10">
          <div class="w-12 h-12 rounded-full bg-gold/20 flex items-center justify-center">
            <span class="font-display text-heading font-bold text-gold">{{ author | default: "Apex Agency" | slice: 0 }}</span>
          </div>
          <div>
            <p class="font-display text-heading font-semibold text-cloud" itemprop="author">{{ author | default: "Apex Agency" }}</p>
            <p class="text-caption text-cloud/40">{{ author_role | default: "Growth Team" }}</p>
          </div>
          {% if author_social %}
          <a href="{{ author_social }}" class="ml-auto text-cloud/40 hover:text-gold transition-colors" aria-label="Author's LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-cloud to-transparent"></div>
  </section>

  <!-- ── Post Content ──────────────────────────────────── -->
  <section class="section">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-3 lg:col-start-1 max-w-none prose prose-lg prose-midnight" itemprop="articleBody">
          {{ content }}

          <!-- Tags -->
          {% if tags %}
          <div class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-cloud-dark">
            {% for tag in tags %}
            {% unless tag == "posts" %}
            <a href="/blog/tag/{{ tag | slugify }}" class="badge bg-midnight/5 text-midnight/60 hover:bg-midnight/10 transition-colors">
              #{{ tag }}
            </a>
            {% endunless %}
            {% endfor %}
          </div>
          {% endif %}
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-1 lg:col-start-4 lg:row-start-1">
          <div class="sticky top-24 space-y-8">
            <!-- Share -->
            <div class="p-6 rounded-lg bg-cloud-dark/50">
              <h3 class="font-display text-heading font-semibold mb-4">Share</h3>
              <div class="flex gap-3">
                <a href="https://twitter.com/intent/tweet?text={{ title | url_encode }}&url={{ site.url }}{{ page.url }}" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-midnight/5 flex items-center justify-center hover:bg-gold hover:text-midnight transition-colors" aria-label="Share on Twitter">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                </a>
                <a href="https://linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url }}" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-midnight/5 flex items-center justify-center hover:bg-gold hover:text-midnight transition-colors" aria-label="Share on LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="mailto:?subject={{ title | url_encode }}&body={{ site.url }}{{ page.url }}" class="w-10 h-10 rounded-full bg-midnight/5 flex items-center justify-center hover:bg-gold hover:text-midnight transition-colors" aria-label="Share via Email">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </a>
              </div>
            </div>

            <!-- Newsletter Signup -->
            <div class="p-6 rounded-lg bg-midnight text-cloud">
              <h3 class="font-display text-heading font-semibold mb-3">Get Growth Insights</h3>
              <p class="text-body-sm text-cloud/50 mb-4">Weekly strategies from our team.</p>
              <form action="/api/newsletter" method="POST" class="flex flex-col gap-3">
                <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                <label for="sidebar-email" class="sr-only">Email</label>
                <input id="sidebar-email" type="email" name="email" required placeholder="Your email" class="px-3 py-2.5 rounded-sm bg-white/10 border border-white/20 text-cloud text-body-sm placeholder:text-cloud/30 focus:outline-none focus:border-gold">
                <button type="submit" class="btn btn-primary btn-sm w-full">Subscribe</button>
              </form>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ── Related Posts ─────────────────────────────────── -->
  {% assign related_posts = collections.posts | where_exp: "item", "item.data.tags contains category and item.url != page.url" | limit: 3 %}
  {% if related_posts.size > 0 %}
  <section class="section bg-cloud-dark/30">
    <div class="container-page">
      <h2 class="font-display text-heading-xl font-bold mb-12" data-animate>Related Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {% for related in related_posts %}
        <article class="group bg-white rounded-lg shadow-soft hover:shadow-elevated transition-all overflow-hidden" data-animate>
          <a href="{{ related.url }}" class="block">
            <div class="aspect-[16/10] bg-midnight overflow-hidden">
              {% if related.data.thumbnail %}
              <img src="{{ related.data.thumbnail }}" alt="" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              {% else %}
              <div class="w-full h-full bg-gradient-to-br from-midnight-light to-midnight flex items-center justify-center">
                <span class="font-display text-display text-gold/30">{{ related.data.title | slice: 0 }}</span>
              </div>
              {% endif %}
            </div>
            <div class="p-5">
              <span class="badge badge-gold mb-2 inline-block">{{ related.data.category | default: "Insights" }}</span>
              <h3 class="font-display text-heading font-semibold group-hover:text-gold transition-colors">{{ related.data.title }}</h3>
              <p class="text-body-sm text-midnight/50 mt-2">{{ related.data.excerpt | truncate: 100 }}</p>
            </div>
          </a>
        </article>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}
</article>
