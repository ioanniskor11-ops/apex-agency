---
layout: default
---

<!-- ── Work Header ───────────────────────────────────── -->
<section class="relative pt-32 pb-16 md:pt-40 md:pb-24 bg-midnight overflow-hidden">
  <div class="absolute inset-0 bg-noise"></div>
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-64 h-64 bg-gold/5 rounded-full blur-3xl"></div>
  </div>

  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <span class="inline-block px-4 py-1.5 bg-gold/15 text-gold text-caption font-semibold uppercase tracking-widest rounded-sm mb-6">
        Portfolio
      </span>
      <h1 class="font-display text-display-lg md:text-display-xl font-bold text-cloud leading-tight">
        {{ title | default: "Our Work" }}
      </h1>
      <p class="mt-6 text-body-lg text-cloud/70 max-w-2xl">
        {{ description | default: "Transforming brands through strategy, creativity, and technology." }}
      </p>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-cloud to-transparent"></div>
</section>

<!-- ── Work Content ──────────────────────────────────── -->
{{ content }}
