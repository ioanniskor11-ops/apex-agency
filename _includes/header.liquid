<header data-header class="header" role="banner" aria-label="Site header">
  <div class="container-page">
    <div class="header-inner">
      <!-- Logo -->
      <a href="/" class="header-logo" aria-label="{{ site.name }} — Home">
        {% if site.brand.logo_path contains '.svg' %}
        <img src="{{ site.brand.logo_path }}" alt="{{ site.name }}" class="h-8 md:h-10 w-auto" width="160" height="40">
        {% else %}
        <span class="font-display text-2xl font-bold">
          <span class="text-gold">Apex</span>
          <span class="text-cloud">Agency</span>
        </span>
        {% endif %}
      </a>

      <!-- Desktop Navigation -->
      <nav class="header-nav" aria-label="Main navigation">
        {% for item in navigation.main %}
        {% if item.children %}
        <div class="relative group" data-nav-dropdown>
          <button class="flex items-center gap-1.5 text-cloud hover:text-gold transition-colors text-body-sm font-medium py-2" aria-haspopup="true" aria-expanded="false">
            {{ item.label }}
            <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-56 bg-cloud rounded-lg shadow-elevated py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50" role="menu">
            {% for child in item.children %}
            <a href="{{ child.url }}" class="block px-4 py-2.5 text-body-sm text-midnight hover:bg-gold/10 hover:text-gold transition-colors" role="menuitem">
              {{ child.label }}
            </a>
            {% endfor %}
          </div>
        </div>
        {% else %}
        <a href="{{ item.url }}" class="text-cloud hover:text-gold transition-colors text-body-sm font-medium py-2" {{ 'aria-current="page"' if page.url == item.url }}>
          {{ item.label }}
        </a>
        {% endif %}
        {% endfor %}
      </nav>

      <!-- Desktop CTA -->
      <a href="/contact" class="header-cta">
        Start a Project
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <!-- Mobile Menu Button -->
      <button data-mobile-menu-toggle class="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</header>
