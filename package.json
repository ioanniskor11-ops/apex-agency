{
  "name": "apex-agency",
  "version": "1.0.0",
  "description": "Apex Agency — The world's most trusted growth partner for premium brands",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "eleventy --serve --port=8080",
    "dev:backend": "node _src/server/index.js --watch",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "eleventy",
    "build:backend": "node _src/server/build.js",
    "start": "node _src/server/index.js",
    "test": "jest",
    "lint": "eslint . --ext .js,.liquid",
    "security:audit": "npx snyk test",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@sanity/block-content-to-html": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.0.8",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-request-id": "^2.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "liquidjs": "^10.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "sanitize-html": "^2.11.0",
    "sharp": "^0.33.1",
    "slugify": "^1.6.6",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@11ty/eleventy-plugin-rss": "^1.2.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cssnano": "^6.0.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.32",
    "snyk": "^1.1266.0",
    "tailwindcss": "^3.4.0",
    "terser": "^5.27.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
